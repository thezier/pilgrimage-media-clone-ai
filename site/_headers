# Cloudflare Pages cache rules.
#
# Note the asymmetry: fonts and generated images get long immutable caches
# because their contents never change under a given name. The hand-written CSS
# and JS deliberately do NOT, because they are edited in place under a stable
# filename — a long cache there is exactly how a stylesheet edit silently fails
# to appear for hours (which is why the older hand-built clone needed a `?v=`
# cache-buster). Pages purges its own edge on deploy; `must-revalidate` covers
# any intermediary that doesn't.

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Generated at build time with content-specific names.
# Note the `:slug` placeholder rather than a second `*`: only ONE splat is
# allowed per pattern, so `/portfolio/*/img/*` silently matched nothing and
# these fell through to the default. A placeholder matches a single path
# segment, which leaves the one splat for the filename.
/portfolio/:slug/img/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=604800

/css/*
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Sensible defaults everywhere. No CSP here — the site loads no third-party
# resources at all, so tightening it further is a later refinement rather than
# something to guess at now.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
